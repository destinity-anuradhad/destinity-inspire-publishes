@model  IEnumerable<Scienter.HotelERP.Common.Domain.Market>

@{
    ViewBag.Title = "Markets";
}

<div class="table-responsive">
    <table class="table table-striped"
           id="existingMarketGrid">
        <thead>
            <tr>
                <th class="text-primary">
                    @Html.DisplayNameFor(model => model.Name)
                </th>
                <th class="col-md-1 text-primary">
                    @Html.DisplayNameFor(model => model.IsActive)
                </th>
                <th class="col-md-1 hidden-print"></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td class="col-md-1">
                        <div class="form-group checkbox">
                            <label>
                                @Html.DisplayFor(modelItem => item.IsActive)
                                <span class="hidden">
                                    @if (item.IsActive)
                                    {
                                        @:Active
                                    }
                                    else
                                    {
                                        @:Inactive
                                    }
                                </span>
                            </label>
                        </div>
                    </td>
                    <td class="hidden-print text-right">
                        @*<a class="btn btn-theme-color-2 btn-sm call-popup-model" id="btnPrint" data-title="Alert Type - @item.Name" data-href="/administration/markets/print/@item.Id">
                                <span class="glyphicon glyphicon-print"></span>
                            </a>*@

                        <a class="btn btn-theme-color-2 btn-sm" id="btnEdit" data-ajax="true" data-ajax-mode="replace" data-ajax-update="#content" href="/administration/markets/edit/@item.Id">
                            <span class="glyphicon glyphicon-pencil"></span>
                        </a>

                        @*<a class="btn btn-danger btn-sm call-popup-model-delete" id="btnDelete" data-href="/administration/markets/delete/@item.Id">
                                <span class="glyphicon glyphicon-trash"></span>
                            </a>*@

                        <a class="btn btn-danger btn-sm js-delete-market"
                           data-href="/administration/markets/delete/@item.Id">
                            <span class="glyphicon glyphicon-trash"></span>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div id="deleteAlert" class="alert" style="display:none;"></div>
<script>
    $(document).ready(function () {
        $('#existingMarketGrid').DataTable(
            {
                //"dom": '<"top"ifb>rt<"bottom"lp><"clear">',
                searching: true,
                ordering: true,
                //"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                dom: 'Bfrtipl',
                select: true,
                buttons: [
                            'copy',
                            'excel',
                            'csv',
                            'pdf',
                            'print'
                ],
                scrollY: '58vh',
            } );
    });

    function showDeleteAlert(type, message) {
        var $a = $("#deleteAlert");
        $a.removeClass("alert-success alert-danger alert-warning alert-info")
            .addClass("alert alert-" + type)
            .html(message)
            .stop(true, true)
            .fadeIn(150);

        setTimeout(function () { $a.fadeOut(250); }, 4000);
    }

    $(document).on("click", ".js-delete-market", function (e) {
        e.preventDefault();

        var url = $(this).data("href");
        if (!url) return;

        if (!confirm("Are you sure you want to delete this record?"))
            return;

        $.ajax({
            url: url,
            type: "GET",
            dataType: "json",
            success: function (res) {
                if (res && res.success) {
                    showDeleteAlert("success", res.message || "Deleted successfully.");
                    // refresh page or grid
                    location.reload();
                } else {
                    showDeleteAlert("danger", (res && res.message) ? res.message : "Delete failed.");
                }
            },
            error: function () {
                showDeleteAlert("danger", "Server error occurred.");
            }
        });
    });
</script>