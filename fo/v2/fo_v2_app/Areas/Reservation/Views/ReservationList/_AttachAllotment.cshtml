        $('body').off('click', '.btn-remove-allotment').on('click', '.btn-remove-allotment', function (e) {
            e.preventDefault();

            var $btn = $(this);

            // ✅ use clicked row reservation id if available, otherwise fallback to hidden
            var reservationHeaderId =
                ($btn.attr('data-reservation-heaader-id') || $btn.data('reservation-heaader-id') || $('#ReservationHeaderIdForAllotment').val());

            var allotmentHeaderId =
                ($btn.data('allotmentheaderid') || $btn.attr('data-allotmentheaderid') || $btn.attr('AllotmentHeaderId') || 0);

            var roomCategoryId =
                ($btn.data('roomcategoryid') || $btn.attr('data-roomcategoryid') || $btn.attr('RoomCategoryId') || 0);

            allotmentHeaderId = parseInt(allotmentHeaderId, 10) || 0;
            roomCategoryId = parseInt(roomCategoryId, 10) || 0;
            reservationHeaderId = parseInt(reservationHeaderId, 10) || 0;

            if (!(reservationHeaderId > 0) || !(allotmentHeaderId > 0) || !(roomCategoryId > 0)) {
                ShowWarningMessage('Unable to identify allotment to remove. Please refresh and try again.');
                return;
            }

            $.ajax({
                url: '/Reservation/ReservationList/RemoveAllotment',
                dataType: 'json',
                method: 'get',
                data: {
                    ReservationHeaderId: reservationHeaderId,
                    AllotmentHeaderId: allotmentHeaderId,
                    RoomCategoryId: roomCategoryId
                },
                success: function () {
                    ShowSuccessMessage('Allotment removed.');

                    selectedAllotmentHeaderId = 0;
                    $('#AllotmentHeader,#RoomCategory,#ReservationRoomCategoryId').val(0);
                    $('.allotment-checkbox').prop('disabled', false);

                    setTimeout(function () {
                        LoadReservationGrid();
                        LoadReservationList();
                        LoadAllotmnetDetailList();
                    }, 2500);
                }
            });
        });






