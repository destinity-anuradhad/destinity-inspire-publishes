    <form id="allotmentDetailList">
        <div class="row">
            <div class="col-md-12">
                <fieldset class="the-fieldset">
                    <legend class="the-legend"><font size="2"></font> Allotment Details</legend>
                    <div id="AllotmentList" overflow-x:hidden; overflow-y:scroll;">
                        @if (Model.Count > 0)
                        {
                            <input type="hidden" id="AllotmentHeader" name="AllotmentHeader" value="0">
                            <input type="hidden" id="RoomCategory" name="RoomCategory" value="0">
                            <input type="hidden" id="ReservationRoomCategoryId" name="ReservationRoomCategoryId" value="0">
                            <input type="hidden" id="Model" name="Model" value="@Model">
                        }
                        else
                        {

                        }

                        <table class="table table-striped table-hover" id="allotmentDetailGrid" cellspacing="5">
                            <tr>
                                <th></th>
                                <th>Allotment</th>
                                <th>Room Category</th>
                                <th class="number">Tot.</th>
                                <th class="number">Balance</th>
                                <th hidden></th>
                            </tr>
                        </table>
                    </div>
                </fieldset>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <fieldset class="the-fieldset">
