        function ToggleApplyButton() {
            var hasAllotment = (selectedAllotmentHeaderId > 0);
            var hasReservation = ($('#reservationGridForAllotment .list-checkBox:checked').length > 0);

            if (hasAllotment && hasReservation) {
                $('#btnApplyAllotment')
                    .prop('disabled', false)
                    .css('text-decoration', 'none');
            } else {
                $('#btnApplyAllotment')
                    .prop('disabled', true)
                    .css('text-decoration', 'line-through');
            }
        }

