        // Allotment checkbox change (single-select + filter reservation checkboxes)
        $('body').off('change', '.allotment-checkbox').on('change', '.allotment-checkbox', function () {

                var $this = $(this);

                if ($this.is(':checked')) {

                    // store selected allotment header id
                    selectedAllotmentHeaderId = $this.data('allotmentheaderid') || 0;

                    // ✅ NEW: update hidden fields based on selected allotment
                    $('#AllotmentHeader').val(selectedAllotmentHeaderId);
                    $('#RoomCategory').val($this.data('roomcategoryid') || 0);
                    $('#ReservationRoomCategoryId').val($this.data('reservationroomcategoryid') || 0);

                    // disable other allotment checkboxes
                    $('.allotment-checkbox').not($this).prop('disabled', true);

                    // get selected allotment room category
                    var selectedRoomCategoryId = String($this.data('roomcategoryid') || '');

                    // disable reservation checkboxes that don't match
                    $('#reservationGridForAllotment .list-checkBox').each(function () {
                        var $cb = $(this);

                        // keep those that are already disabled by your grid logic
                        if ($cb.is(':disabled')) return;

                        var resRoomCategoryId = String($cb.data('roomcategoryid') || '');

                        if (resRoomCategoryId !== selectedRoomCategoryId) {
                            $cb.prop('checked', false)
                                .prop('disabled', true)
                                .attr('data-filter-disabled', '1'); // mark as disabled by filter
                        } else {
                            $cb.prop('disabled', false);
                        }
                    });

                } else {

                    // reset selected allotment
                    selectedAllotmentHeaderId = 0;

                    $('#AllotmentHeader').val(0);
                    $('#RoomCategory').val(0);
                    $('#ReservationRoomCategoryId').val(0);

                    // enable all allotment checkboxes
                    $('.allotment-checkbox').prop('disabled', false);

                    // re-enable only the reservation checkboxes we disabled via filter
                    $('#reservationGridForAllotment .list-checkBox[data-filter-disabled="1"]')
                        .prop('disabled', false)
                        .removeAttr('data-filter-disabled');
            }

             ToggleApplyButton();
            });

        $('body').off('change', '.list-checkBox').on('change', '.list-checkBox', function () {
            ToggleApplyButton();
        });


    </script>
