{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "RestaurantHotelResConnectionString": "{{RestaurantHotelResConnectionString}}"
  },
  "AppSettings": {
    "IsAzureEntraIDEnable": "{{IsAzureEntraIDEnable}}"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "{{TenantId}}",
    "ClientId": "{{ClientId}}",
    "ClientSecret": "{{ClientSecret}}",
    "RedirectUri": "{{RedirectUri}}",
    "CallbackPath": "/signin-oidc"
  }
}
